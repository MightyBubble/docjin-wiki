# Server listen port
DOCJIN_SERVER_PORT=3001

# Workspace storage root (absolute path or relative to server/)
DOCJIN_WORKSPACES_ROOT=./workspaces

# Default workspace id
DOCJIN_DEFAULT_WORKSPACE=default

# Optional template directory for seeding new/default workspace content
DOCJIN_TEMPLATE_DATA_DIR=./data

# CORS allow-list (comma separated). Empty means allow all in dev.
# DOCJIN_CORS_ORIGINS=http://localhost:5178,http://127.0.0.1:5178
DOCJIN_CORS_ORIGINS=

# Enable request logs
DOCJIN_LOG_REQUESTS=false
